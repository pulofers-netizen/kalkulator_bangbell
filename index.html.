<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BANG BELL PRO | Premium Seller Tool</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root { --brand-primary: #0f172a; --brand-accent: #2563eb; --brand-gold: #fbbf24; --bg: #f1f5f9; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); padding: 15px; color: var(--brand-primary); margin: 0; }
        .wrapper { max-width: 480px; margin: auto; }
        
        /* CSS UNTUK GERBANG KUNCI AKSES */
        #gatekeeper { text-align: center; margin-top: 100px; animation: fadeIn 0.5s; }
        .gate-card { background: white; padding: 40px; border-radius: 24px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); border: 2px solid var(--brand-primary); }
        .gate-icon { font-size: 3rem; margin-bottom: 20px; color: var(--brand-gold); }
        .gate-card h3 { margin: 0; font-size: 1.2rem; color: var(--brand-primary); }
        .gate-card p { font-size: 0.75rem; color: #64748b; margin: 10px 0 25px; }
        
        /* CSS UNTUK TAMPILAN UTAMA (AWALNYA TERSEMBUNYI) */
        #mainContent { display: none; animation: fadeIn 0.5s; }
        
        /* HEADER & CARD DESIGN */
        .brand-header { background: var(--brand-primary); padding: 30px 20px; border-radius: 24px 24px 0 0; text-align: center; color: white; border-bottom: 4px solid var(--brand-gold); }
        .brand-header h1 { font-size: 1.6rem; font-weight: 800; margin: 0; letter-spacing: 1px; color: var(--brand-gold); }
        .brand-header p { font-size: 0.7rem; opacity: 0.9; margin-top: 5px; text-transform: uppercase; letter-spacing: 3px; font-weight: 600; }
        .main-card { background: white; border-radius: 0 0 24px 24px; padding: 25px; box-shadow: 0 15px 30px rgba(0,0,0,0.1); margin-bottom: 20px; }
        
        /* FORM ELEMENTS */
        label { display: block; font-size: 0.7rem; font-weight: 800; color: #64748b; margin: 15px 0 5px; text-transform: uppercase; }
        select, input { width: 100%; padding: 14px; border: 2px solid #f1f5f9; border-radius: 12px; font-size: 15px; font-weight: 600; box-sizing: border-box; background: #f8fafc; outline: none; transition: 0.3s; }
        select:focus, input:focus { border-color: var(--brand-accent); background: white; }
        
        /* CAMPAIGN BOX */
        .promo-box { background: #fffbeb; padding: 15px; border-radius: 16px; border: 1px solid #fef3c7; margin-top: 15px; }
        .check-item { display: flex; align-items: center; gap: 10px; margin: 10px 0; font-size: 0.8rem; font-weight: 700; color: #92400e; }
        input[type="checkbox"] { width: 18px; height: 18px; cursor: pointer; }
        
        /* BUTTONS */
        .btn-brand { width: 100%; padding: 18px; background: var(--brand-primary); color: white; border: none; border-radius: 16px; font-size: 1rem; font-weight: 800; margin-top: 25px; cursor: pointer; transition: 0.2s; border: 1px solid var(--brand-gold); }
        .btn-brand:active { transform: scale(0.97); }
        .btn-gate { margin-top: 10px; background: var(--brand-accent); border: none; }
        
        /* RESULT DESIGN */
        #result { display: none; margin-top: 25px; }
        .res-premium { background: white; padding: 25px; border-radius: 24px; text-align: center; border: 2px solid var(--brand-primary); position: relative; overflow: hidden; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .res-premium::before { content: "BANG BELL VERIFIED"; position: absolute; top: 12px; left: -35px; background: var(--brand-gold); color: var(--brand-primary); font-size: 0.5rem; font-weight: 800; padding: 5px 45px; transform: rotate(-45deg); }
        .res-net { font-size: 2.2rem; font-weight: 800; color: var(--brand-accent); margin: 10px 0; }
        
        /* FOOTER BRANDING */
        .footer-brand { text-align: center; font-size: 0.65rem; color: #94a3b8; margin-top: 20px; padding-bottom: 30px; line-height: 1.5; }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

<div class="wrapper">
    <div id="gatekeeper">
        <div class="gate-card">
            <div class="gate-icon">🔒</div>
            <h3>Akses Premium Terkunci</h3>
            <p>Masukkan kunci akses yang kamu dapatkan setelah pembelian untuk membuka tools Bang Bell Pro.</p>
            <input type="text" id="accessKey" placeholder="Masukkan Kunci Akses (Case Sensitive)">
            <button class="btn-brand btn-gate" onclick="checkKey()">BUKA AKSES SEKARANG</button>
        </div>
        <div class="footer-brand">🔒 <b>BANG BELL INTELLIGENCE</b>. All Rights Reserved.</div>
    </div>

    <div id="mainContent">
        <div class="brand-header">
            <h1>BANG BELL PRO</h1>
            <p>E-Commerce Profit Intelligence</p>
        </div>

        <div class="main-card">
            <label>Marketplace & Tipe Seller</label>
            <div style="display: flex; gap: 10px;">
                <select id="platform" onchange="updateTipe()">
                    <option value="shopee">Shopee Indonesia</option>
                    <option value="tiktok">TikTok Shop</option>
                    <option value="tokopedia">Tokopedia</option>
                </select>
                <select id="tipeSeller" onchange="refresh()"></select>
            </div>

            <label>Kategori Produk Utama</label>
            <select id="kat" onchange="refresh()">
                <option value="0">Kategori 1 (Fashion, FnB, Skincare)</option>
                <option value="1">Kategori 2 (Elektronik, Olahraga)</option>
                <option value="2">Kategori 3 (Otomotif, Hobi)</option>
                <option value="3">Kategori 4 (Gadget, HP)</option>
            </select>

            <div class="promo-box">
                <div class="check-item"><input type="checkbox" id="gongkir" onchange="refresh()"><span>Campaign / Gratis Ongkir Xtra</span></div>
                <div class="check-item"><input type="checkbox" id="cb" onchange="refresh()"><span>Cashback Xtra Program</span></div>
                <label style="color: #92400e; margin-top: 5px;">Diskon Voucher Toko (Rp)</label>
                <input type="number" id="vch" value="0" onchange="refresh()">
            </div>

            <div style="text-align:center; padding: 15px 0;">
                <span style="font-size: 0.65rem; font-weight: 800; color: #94a3b8;">SERVICE FEE RATE:</span>
                <span id="rateView" style="font-weight: 800; color: var(--brand-accent); font-size: 1.2rem; margin-left: 5px;">0%</span>
            </div>

            <label>Total Omzet</label><input type="number" id="omzet" placeholder="Rp">
            <div style="display: flex; gap: 10px;">
                <div style="flex: 1;"><label>Modal Satuan</label><input type="number" id="hpp" placeholder="Rp"></div>
                <div style="flex: 0.5;"><label>Qty</label><input type="number" id="qty" placeholder="0"></div>
            </div>
            <label>Biaya Iklan</label><input type="number" id="ads" placeholder="Rp">
            <button class="btn-brand" onclick="calculate()">HITUNG PROFIT BANG BELL</button>
        </div>

        <div id="result">
            <div class="res-premium">
                <span style="font-size: 0.75rem; font-weight: 800; color: #64748b;">REAL NET PROFIT</span>
                <div id="resNet" class="res-net">Rp 0</div>
                <div id="resStatus" style="font-size: 0.8rem; font-weight: 800; margin-bottom: 15px;"></div>
                <div style="display: flex; justify-content: space-around; font-size: 0.7rem; font-weight: 700; color: #64748b; background: #f8fafc; padding: 10px; border-radius: 12px;">
                    <span>ADMIN: <span id="rAdm">0</span></span>
                    <span>ROAS: <span id="rRoas">0</span>x</span>
                </div>
            </div>
        </div>

        <div class="footer-brand">&copy; 2026 <b>BANG BELL INTELLIGENCE</b>. All Rights Reserved.</div>
    </div>
</div>

<script>
    // LOGIKA KUNCI AKSES (CUSTOMIZE DI SINI)
    // Ganti kata 'BANG-BELL-CUAN-2026' dengan kunci rahasia pilihan kamu!
    const CORRECT_KEY = "BANG-BELL-CUAN-2026"; 

    function checkKey() {
        const inputKey = document.getElementById('accessKey').value;
        if(inputKey === CORRECT_KEY) {
            document.getElementById('gatekeeper').style.display = 'none';
            document.getElementById('mainContent').style.display = 'block';
            updateTipe(); // Inisialisasi awal kalkulator
        } else {
            alert("❌ Kunci Akses Salah! Silakan cek kembali atau hubungi admin.");
        }
    }

    // LOGIKA KALKULATOR BANG BELL PRO (TETAP SAMA)
    const data = {
        shopee: { "Non-Star / Reguler": [4.25, 3.8, 3.2, 2.5], "Star": [5.5, 4.8, 4.0, 3.2], "Star+": [6.0, 5.2, 4.5, 3.5], "Shopee Mall": [8.5, 7.5, 6.0, 4.5] },
        tiktok: { "Non-PowerShop": [4.0, 3.5, 3.0, 2.0], "PowerShop (Verified)": [6.0, 5.0, 4.0, 3.0] },
        tokopedia: { "Reguler": [3.0, 2.5, 2.0, 1.5], "Power Merchant": [5.0, 4.5, 3.8, 2.5], "Official Store": [8.0, 7.0, 6.0, 4.0] }
    };

    function updateTipe() {
        const p = document.getElementById('platform').value;
        const s = document.getElementById('tipeSeller');
        s.innerHTML = "";
        Object.keys(data[p]).forEach(t => {
            let o = document.createElement('option'); o.value = t; o.innerText = t; s.appendChild(o);
        });
        refresh();
    }

    function refresh() {
        const p = document.getElementById('platform').value;
        const t = document.getElementById('tipeSeller').value;
        const kat = document.getElementById('kat');
        if(!t) return; // Mencegah eror saat mainContent belum terbuka
        const k = parseInt(kat.value);
        let r = data[p][t][k];
        if(document.getElementById('gongkir').checked) r += 4.0;
        if(document.getElementById('cb').checked) r += 1.4;
        document.getElementById('rateView').innerText = r.toFixed(2) + "%";
        return r / 100;
    }

    function calculate() {
        const omzet = parseFloat(document.getElementById('omzet').value) || 0;
        const hpp = parseFloat(document.getElementById('hpp').value) || 0;
        const qty = parseFloat(document.getElementById('qty').value) || 0;
        const ads = parseFloat(document.getElementById('ads').value) || 0;
        const vch = parseFloat(document.getElementById('vch').value) || 0;
        const rAdmin = refresh();

        if(omzet <= 0) return alert("Masukkan nominal omzet!");

        const tHpp = hpp * qty;
        const tAdm = omzet * rAdmin;
        const tVch = vch * qty;
        const net = omzet - tHpp - ads - tAdm - tVch;
        const roas = ads > 0 ? (omzet/ads).toFixed(2) : "0";

        document.getElementById('result').style.display = 'block';
        document.getElementById('resNet').innerText = "Rp " + net.toLocaleString('id-ID');
        document.getElementById('rAdm').innerText = "Rp " + tAdm.toLocaleString('id-ID');
        document.getElementById('rRoas').innerText = roas;

        const st = document.getElementById('resStatus');
        if(net > 0) { st.innerText = "KONDISI: PROFIT AMAN ✅"; st.style.color = "#16a34a"; }
        else { st.innerText = "KONDISI: BONCOS/RUGI ❌"; st.style.color = "#dc2626"; }
        window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
    }
</script>

</body>
</html>
